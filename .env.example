# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=investiga_tijucas
POSTGRES_USER=investiga
POSTGRES_PASSWORD=investiga_dev
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=investiga
RABBITMQ_PASSWORD=investiga_dev
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenRouter (LLM) ─────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Minha Receita ─────────────────────────────────────────
MINHA_RECEITA_BASE_URL=https://minhareceita.org

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000
